Table BEX_ACCOUNT {
  ACC_ID bigint [pk, increment]
  ACC_EMAIL varchar(150)
  ACC_PASSWORD_HASH varchar(255)
  ACC_PROVIDER varchar(30)
  ACC_PROVIDER_ID varchar(150)
  ACC_STATUS varchar(30)
  ACC_CREATED_AT timestamp
  ACC_UPDATED_AT timestamp
}

Table BEX_PROFILE {
  PRF_ID bigint [pk, increment]
  ACC_ID bigint
  PRF_NAME varchar(150)
  PRF_PHONE varchar(20)
  PRF_DOCUMENT varchar(20)
  PRF_PHOTO_URL varchar(500)
  PRF_CREATED_AT timestamp
  PRF_UPDATED_AT timestamp
}

Table BEX_STORE {
  STR_ID bigint [pk, increment]
  STR_PUBLIC_ID char(32) [not null, unique, note: 'Immutable public identifier assigned by the application service']
  ACC_ID bigint [not null, note: 'Account that structurally owns the store']
  STR_NAME varchar(200) [not null]
  STR_SLUG varchar(100) [not null, unique]
  STR_DESCRIPTION varchar(1000)
  STR_STATUS varchar(20) [not null, default: 'DRAFT', note: 'DRAFT, ACTIVE, SUSPENDED or CLOSED']
  STR_LOGO_URL varchar(1000)
  STR_COVER_URL varchar(1000)
  STR_LOCALE_CODE varchar(10) [not null, default: 'pt-BR']
  STR_TIMEZONE_NAME varchar(64) [not null, default: 'America/Sao_Paulo']
  STR_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  STR_CREATED_BY bigint
  STR_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  STR_UPDATED_BY bigint

  indexes {
    ACC_ID [name: 'IDX_STORE_ACCOUNT']
    STR_STATUS [name: 'IDX_STORE_STATUS']
  }

  Note: 'Store or commercial sales operation structurally owned by an account. ACC_ID is not unique.'
}

Table BEX_STORE_USER {
  STU_ID bigint [pk, increment]
  STU_PUBLIC_ID char(32) [not null, unique]
  STR_ID bigint [not null]
  ACC_ID bigint [not null]
  STU_ROLE_CODE varchar(50) [not null, note: 'ADMIN, MANAGER, ATTENDANT or COLLABORATOR; no default']
  STU_STATUS varchar(20) [not null, default: 'ACTIVE', note: 'ACTIVE or INACTIVE']
  STU_JOINED_AT timestamp [not null]
  STU_LEFT_AT timestamp
  STU_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  STU_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  STU_CREATED_BY bigint
  STU_UPDATED_BY bigint

  indexes {
    (`CASE WHEN STU_STATUS = 'ACTIVE' THEN STR_ID END`, `CASE WHEN STU_STATUS = 'ACTIVE' THEN ACC_ID END`) [unique, name: 'UK_STU_STORE_ACCOUNT_ACTIVE']
    STR_ID [name: 'IDX_STORE_USER_STORE']
    ACC_ID [name: 'IDX_STORE_USER_ACCOUNT']
    STU_ROLE_CODE [name: 'IDX_STORE_USER_ROLE']
    STU_STATUS [name: 'IDX_STORE_USER_STATUS']
  }

  checks {
    `STU_ROLE_CODE IN ('ADMIN', 'MANAGER', 'ATTENDANT', 'COLLABORATOR')` [name: 'CK_STU_ROLE_CODE']
    `STU_STATUS IN ('ACTIVE', 'INACTIVE')` [name: 'CK_STU_STATUS']
  }

  Note: 'Operational account membership in a store. No conventional unique constraint exists on STR_ID plus ACC_ID, preserving INACTIVE history. STU_CREATED_BY and STU_UPDATED_BY reference BEX_ACCOUNT.ACC_ID.'
}

Table BEX_CATEGORY {
  CAT_ID bigint [pk, increment]
  CAT_PUBLIC_ID char(32) [not null, unique]
  CAT_NAME varchar(200) [not null]
  CAT_SLUG varchar(120) [not null, unique]
  CAT_DESCRIPTION varchar(1000)
  CAT_STATUS varchar(20) [not null, default: 'ACTIVE', note: 'ACTIVE or INACTIVE']
  CAT_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  CAT_CREATED_BY bigint
  CAT_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  CAT_UPDATED_BY bigint

  indexes {
    CAT_STATUS [name: 'IDX_CATEGORY_STATUS']
  }

  Note: 'Official classification used to organize catalog products.'
}

Table BEX_BRAND {
  BRD_ID bigint [pk, increment]
  BRD_PUBLIC_ID char(32) [not null, unique]
  BRD_NAME varchar(200) [not null]
  BRD_SLUG varchar(120) [not null, unique]
  BRD_DESCRIPTION varchar(1000)
  BRD_STATUS varchar(20) [not null, default: 'ACTIVE', note: 'ACTIVE or INACTIVE']
  BRD_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  BRD_CREATED_BY bigint
  BRD_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  BRD_UPDATED_BY bigint

  indexes {
    BRD_STATUS [name: 'IDX_BRAND_STATUS']
  }

  Note: 'Official brand reference used to classify catalog products.'
}

Table BEX_PRODUCT {
  PRD_ID bigint [pk, increment]
  PRD_PUBLIC_ID char(32) [not null, unique]
  STR_ID bigint [not null]
  CAT_ID bigint [not null]
  BRD_ID bigint
  PRD_TITLE varchar(200) [not null]
  PRD_SLUG varchar(200) [not null]
  PRD_DESCRIPTION varchar(4000)
  PRD_PRICE decimal(12,2) [not null]
  PRD_QUANTITY bigint [not null]
  PRD_CONDITION varchar(20) [not null]
  PRD_WEIGHT decimal(10,3)
  PRD_WIDTH decimal(10,3)
  PRD_HEIGHT decimal(10,3)
  PRD_LENGTH decimal(10,3)
  PRD_STATUS varchar(20) [not null, default: 'DRAFT']
  PRD_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PRD_CREATED_BY bigint
  PRD_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PRD_UPDATED_BY bigint

  indexes {
    (STR_ID, PRD_SLUG) [unique, name: 'UK_PRODUCT_STORE_SLUG']
    (PRD_ID, STR_ID) [unique, name: 'UK_PRODUCT_ID_STORE']
    CAT_ID [name: 'IDX_PRODUCT_CATEGORY']
    BRD_ID [name: 'IDX_PRODUCT_BRAND']
    PRD_STATUS [name: 'IDX_PRODUCT_STATUS']
    PRD_PRICE [name: 'IDX_PRODUCT_PRICE']
  }
}

Table BEX_PRODUCT_IMAGE {
  PIM_ID bigint [pk, increment]
  PIM_PUBLIC_ID char(32) [not null, unique]
  PRD_ID bigint [not null]
  PIM_URL varchar(1000) [not null]
  PIM_ALT_TEXT varchar(200)
  PIM_SORT_ORDER bigint [not null]
  PIM_IS_PRIMARY int [not null, default: 0]
  PIM_STATUS varchar(20) [not null, default: 'ACTIVE']
  PIM_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PIM_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PIM_CREATED_BY bigint
  PIM_UPDATED_BY bigint
}

Table BEX_PRODUCT_QUESTION {
  PQA_ID bigint [pk, increment]
  PQA_PUBLIC_ID char(32) [not null, unique]
  PRD_ID bigint [not null]
  STR_ID bigint [not null]
  PFL_QUESTION_BY bigint [not null]
  PFL_ANSWERED_BY bigint
  PQA_QUESTION_TEXT varchar(4000) [not null]
  PQA_ANSWER_TEXT varchar(4000)
  PQA_ASKED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PQA_ANSWERED_AT timestamp
  PQA_STATUS varchar(20) [not null, default: 'ACTIVE']
  PQA_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PQA_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PQA_CREATED_BY bigint
  PQA_UPDATED_BY bigint
}

Table BEX_CART {
  CRT_ID bigint [pk, increment]
  CRT_PUBLIC_ID char(32) [not null, unique]
  PFL_ID bigint [not null]
  CRT_STATUS varchar(20) [not null, default: 'ACTIVE']
  CRT_EXPIRES_AT timestamp
  CRT_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  CRT_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  CRT_CREATED_BY bigint
  CRT_UPDATED_BY bigint

  indexes {
    PFL_ID [name: 'IDX_CART_PROFILE']
    CRT_STATUS [name: 'IDX_CART_STATUS']
    (`CASE WHEN CRT_STATUS = 'ACTIVE' THEN PFL_ID END`) [unique, name: 'UK_CART_ACTIVE_PROFILE']
  }

  Note: 'Temporary multi-store purchase intention without stock reservation.'
}

Table BEX_CART_ITEM {
  CTI_ID bigint [pk, increment]
  CTI_PUBLIC_ID char(32) [not null, unique]
  CRT_ID bigint [not null]
  PRD_ID bigint [not null]
  STR_ID bigint [not null]
  CTI_QUANTITY bigint [not null]
  CTI_UNIT_PRICE decimal(12,2) [not null]
  CTI_STATUS varchar(20) [not null, default: 'ACTIVE']
  CTI_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  CTI_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  CTI_CREATED_BY bigint
  CTI_UPDATED_BY bigint

  indexes {
    CRT_ID [name: 'IDX_CART_ITEM_CART']
    PRD_ID [name: 'IDX_CART_ITEM_PRODUCT']
    STR_ID [name: 'IDX_CART_ITEM_STORE']
    CTI_STATUS [name: 'IDX_CART_ITEM_STATUS']
    (`CASE WHEN CTI_STATUS = 'ACTIVE' THEN CRT_ID END`, `CASE WHEN CTI_STATUS = 'ACTIVE' THEN PRD_ID END`) [unique, name: 'UK_CART_ITEM_ACTIVE_PRODUCT']
  }
}

Table BEX_PURCHASE_REQUEST {
  PUR_ID bigint [pk, increment]
  PUR_PUBLIC_ID char(32) [not null, unique]
  PFL_ID bigint [not null]
  PUR_STATUS varchar(30) [not null, default: 'PENDING']
  PUR_REQUESTED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PUR_CONFIRMED_AT timestamp
  PUR_RESPONSE_AT timestamp
  PUR_EXPIRES_AT timestamp
  PUR_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PUR_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PUR_CREATED_BY bigint
  PUR_UPDATED_BY bigint

  indexes {
    PFL_ID [name: 'IDX_PURCHASE_REQUEST_PROFILE']
    PUR_STATUS [name: 'IDX_PURCHASE_REQUEST_STATUS']
    PUR_REQUESTED_AT [name: 'IDX_PURCHASE_REQUEST_REQUESTED_AT']
  }

  Note: 'Multi-store commercial availability request.'
}

Table BEX_PURCHASE_REQUEST_ITEM {
  PRI_ID bigint [pk, increment]
  PRI_PUBLIC_ID char(32) [not null, unique]
  PUR_ID bigint [not null]
  PRD_ID bigint [not null]
  STR_ID bigint [not null]
  PRI_REQUESTED_QUANTITY bigint [not null]
  PRI_CONFIRMED_QUANTITY bigint
  PRI_UNIT_PRICE decimal(12,2) [not null]
  PRI_REJECT_REASON varchar(500)
  PRI_STATUS varchar(30) [not null, default: 'PENDING']
  PRI_CREATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PRI_UPDATED_AT timestamp [not null, default: `SYSTIMESTAMP`]
  PRI_CREATED_BY bigint
  PRI_UPDATED_BY bigint

  indexes {
    PUR_ID [name: 'IDX_PURCHASE_REQUEST_ITEM_REQUEST']
    PRD_ID [name: 'IDX_PURCHASE_REQUEST_ITEM_PRODUCT']
    STR_ID [name: 'IDX_PURCHASE_REQUEST_ITEM_STORE']
    PRI_STATUS [name: 'IDX_PURCHASE_REQUEST_ITEM_STATUS']
  }
}

Ref: BEX_PROFILE.ACC_ID > BEX_ACCOUNT.ACC_ID
Ref: BEX_STORE.ACC_ID > BEX_ACCOUNT.ACC_ID
Ref: BEX_STORE_USER.STR_ID > BEX_STORE.STR_ID
Ref: BEX_STORE_USER.ACC_ID > BEX_ACCOUNT.ACC_ID
Ref: BEX_STORE_USER.STU_CREATED_BY > BEX_ACCOUNT.ACC_ID
Ref: BEX_STORE_USER.STU_UPDATED_BY > BEX_ACCOUNT.ACC_ID
Ref: BEX_PRODUCT.STR_ID > BEX_STORE.STR_ID
Ref: BEX_PRODUCT.CAT_ID > BEX_CATEGORY.CAT_ID
Ref: BEX_PRODUCT.BRD_ID > BEX_BRAND.BRD_ID
Ref: BEX_PRODUCT_IMAGE.PRD_ID > BEX_PRODUCT.PRD_ID
Ref: BEX_PRODUCT_QUESTION.[PRD_ID, STR_ID] > BEX_PRODUCT.[PRD_ID, STR_ID]
Ref: BEX_PRODUCT_QUESTION.PFL_QUESTION_BY > BEX_PROFILE.PFL_ID
Ref: BEX_PRODUCT_QUESTION.PFL_ANSWERED_BY > BEX_PROFILE.PFL_ID
Ref: BEX_CART.PFL_ID > BEX_PROFILE.PFL_ID
Ref: BEX_CART_ITEM.CRT_ID > BEX_CART.CRT_ID
Ref: BEX_CART_ITEM.[PRD_ID, STR_ID] > BEX_PRODUCT.[PRD_ID, STR_ID]
Ref: BEX_PURCHASE_REQUEST.PFL_ID > BEX_PROFILE.PFL_ID
Ref: BEX_PURCHASE_REQUEST_ITEM.PUR_ID > BEX_PURCHASE_REQUEST.PUR_ID
Ref: BEX_PURCHASE_REQUEST_ITEM.[PRD_ID, STR_ID] > BEX_PRODUCT.[PRD_ID, STR_ID]
